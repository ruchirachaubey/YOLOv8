ions3/labels'\n","true_dir = '/content/drive/MyDrive/Object_detectionProject/HackByte_Dataset/data/test/labels'\n","\n","wrong_class_files = []\n","\n","# Compare each label file\n","for filename in os.listdir(pred_dir):\n","    if filename.endswith('.txt'):\n","        pred_file = os.path.join(pred_dir, filename)\n","        true_file = os.path.join(true_dir, filename)\n","\n","        if not os.path.exists(true_file):\n","            print(f\"❌ True label missing for {filename}\")\n","            continue\n","\n","        with open(pred_file, 'r') as pf, open(true_file, 'r') as tf:\n","            pred_lines = pf.read().splitlines()\n","            true_lines = tf.read().splitlines()\n","\n","            # Compare number of boxes first\n","            if len(pred_lines) != len(true_lines):\n","                print(f\"⚠️ Different number of boxes in {filename}\")\n","                wrong_class_files.append(filename)\n","                continue\n","\n","            # Compare class_ids box by box\n","            for pred_line, true_line in zip(pred_lines, true_lines):\n","                pred_class = int(pred_line.split()[0])\n","                true_class = int(true_line.split()[0])\n","\n","                if pred_class != true_class:\n","                    print(f\"❌ Wrong class in {filename} | Pred: {pred_class}, True: {true_class}\")\n","                    wrong_class_files.append(filename)\n","                    break  # One mismatch is enough to count the file\n","\n","print(f\"\\n🔍 Total files with wrong class prediction: {len(wrong_class_files)}\")\n","print(f\"Files: {wrong_class_files}\")\n"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"HMqFRACmEte7"},"outputs":[],"source":["from google.colab import files\n","files.download('runs/detect/test_predictions/2000000041.jpg')"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"qbPYf26bE9rG"},"outputs":[],"source":["from google.colab import files\n","files.download('runs/detect/test_predictions/3000000033.jpg')"]},{"cell_type":"markdown","metadata":{"id":"K_87VRaBTvKH"},"source":[]},{"cell_type":"code","execution_count":null,"metadata":{"id":"x5IlwmQ1O8mf"},"outputs":[],"source":["import os\n","import cv2\n","import shutil\n","\n","# prediction images\n","pred_img_folder = 'runs/detect/test_predictions3'\n","pred_label_folder = os.path.join(pred_img_folder, 'labels')\n","\n","# ✅ Ground truth labels from test set\n","true_label_folder = '/content/drive/MyDrive/Object_detectionProject/HackByte_Dataset/data/test/labels'\n","\n","# Output folders for failures\n","poor_box_folder = '/content/drive/MyDrive/Object_detectionProject/failures/poor_box'\n","wrong_class_folder = '/content/drive/MyDrive/Object_detectionProject/failures/wrong_class'\n","\n","os.makedirs(poor_box_folder, exist_ok=True)\n","os.makedirs(wrong_class_folder, exist_ok=True)\n","\n","# Convert YOLO to pixel box\n","def convert_bbox(xc, yc, w, h, img_w, img_h):\n","    x1 = (xc - w/2) * img_w\n","    y1 = (yc - h/2) * img_h\n","    x2 = (xc + w/2) * img_w\n","    y2 = (yc + h/2) * img_h\n","    return [x1, y1, x2, y2]\n","\n","# IOU function\n","def get_iou(box1, box2):\n","    xa = max(box1[0], box2[0])\n","    ya = max(box1[1], box2[1])\n","    xb = min(box1[2], box2[2])\n","    yb = min(box1[3], box2[3])\n","\n","    inter_area = max(0, xb - xa) * max(0, yb - ya)\n","    box1_area = (box1[2]-box1[0]) * (box1[3]-box1[1])\n","    box2_area = (box2[2]-box2[0]) * (box2[3]-box2[1])\n","    union_area = box1_area + box2_area - inter_area + 1e-6\n","\n","    iou = inter_area / union_area\n","    return iou\n","\n","# Loop over predicted images\n","for img_name in os.listdir(pred_img_folder):\n","    if not img_name.endswith(('.jpg', '.png')):\n","        continue\n","\n","    img_path = os.path.join(pred_img_folder, img_name)\n","    pred_txt = os.path.join(pred_label_folder, img_name.rsplit('.',1)[0] + '.txt')\n","    true_txt = os.path.join(true_label_folder, img_name.rsplit('.',1)[0] + '.txt')\n","\n","    if not os.path.exists(pred_txt) or not os.path.exists(true_txt):\n","        continue\n","\n","    img = cv2.imread(img_path)\n","    h, w = img.shape[:2]\n","\n","    with open(pred_txt, 'r') as f1, open(true_txt, 'r') as f2:\n","        pred_boxes = f1.readlines()\n","        true_boxes = f2.readlines()\n","\n","    failure_found = False\n","\n","    for t in true_boxes:\n","        tc, tx, ty, tw, th = map(float, t.strip().split())\n","        true_box = convert_bbox(tx, ty, tw, th, w, h)\n","\n","        best_iou = 0\n","        best_pc = -1\n","\n","        for p in pred_boxes:\n","            pc, px, py, pw, ph = map(float, p.strip().split())\n","            pred_box = convert_bbox(px, py, pw, ph, w, h)\n","            iou = get_iou(true_box, pred_box)\n","\n","            if iou > best_iou:\n","                best_iou = iou\n","                best_pc = int(pc)\n","\n","        if best_iou < 0.5:\n","            shutil.copy(img_path, os.path.join(poor_box_folder, img_name))\n","            print(f\"{img_name} → ❌ Poor Box (IOU={best_iou:.2f})\")\n","            failure_found = True\n","            break\n","        elif int(tc) != best_pc:\n","            shutil.copy(img_path, os.path.join(wrong_class_folder, img_name))\n","            print(f\"{img_name} → ❌ Wrong Class\")\n","            failure_found = True\n","            break\n","\n","    if not failure_found:\n","        print(f\"{img_name} → ✅ OK\")\n","\n","print(\"🎯 Done! Failures saved in failures/wrong_class/ and failures/poor_box/\")"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"Ue01JCneTxHw"},"outputs":[],"source":["from google.colab import files\n","files.download('runs/detect/test_predictions/3000000054.jpg')\n","from google.colab import files\n","files.download('runs/detect/test_predictions/1000000056.jpg')"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"GYjZm4ULXfvl"},"outputs":[],"source":[]},{"cell_type":"code","execution_cou